# Optionnel : sans cette clé, PaniQ utilise le moteur local d'estimation inclus.
# À renseigner dans Vercel > Project Settings > Environment Variables.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel : modèle Anthropic à utiliser si la clé API est présente.
ANTHROPIC_MODEL=claude-sonnet-4-6
