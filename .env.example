# PaniQ V1.0.7 Groq API
# L'app fonctionne sans clé API grâce au moteur local.
# Pour activer l'analyse IA serveur sur Vercel :
# Vercel > Project > Settings > Environment Variables

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel : modèle Groq utilisé par /api/analyze
GROQ_MODEL=llama-3.3-70b-versatile
